# go envs
DOCKER_GOOS=linux
DOCKER_GOARCH=amd64
TEST_GOOS=linux # if you work on windows, change this
TEST_GOARCH=amd64

# mode
MODE=development

# localhost cert and key (development only)
LOCALHOST_CERT=localhost_wedding_service.crt
LOCALHOST_KEY=localhost_wedding_service.key

# configuration of mysql service
MYSQL_SERVICE_HOSTNAME=wedding-mysql-service
MYSQL_SERVICE_HTTP_PORT=
MYSQL_SERVICE_HTTPS_PORT=
MYSQL_SERVICE_USER=
MYSQL_SERVICE_PASSWORD=
MYSQL_SERVICE_ROOT_PASSWORD=
MYSQL_SERVICE_DATABASE=

# configuration of wedding service
WEDDING_SERVICE_EXTERNAL_HOSTNAME=example.com
WEDDING_SERVICE_EXTERNAL_HOSTNAME_ALIAS1=www.example.com
WEDDING_SERVICE_HOSTNAME=wedding-go-service
WEDDING_SERVICE_HTTP_PORT=
WEDDING_SERVICE_HTTPS_PORT=