# Application settings
APP_NAME=wedding-go-service
DEBUG=4  # Log level (0=None, 1=Error, 2=Warning, 3=Info, 4=Debug)

# Server configuration
WEDDING_SERVICE_HTTP_PORT=8080
WEDDING_SERVICE_HTTPS_PORT=8443
WEDDING_SERVICE_HOSTNAMES=localhost|wedding-go-service|wedding-prometheus|wedding-grafana

# Certificate paths (generated with: make generate)
SELF_SIGNED_CERT_PATH=./webserver/certificate/self_sign_cert/localhost_wedding_service.crt
SELF_SIGNED_KEY_PATH=./webserver/certificate/self_sign_cert/localhost_wedding_service.key

# MySQL configuration
MYSQL_SERVICE_HOSTNAME=wedding-mysql-service
MYSQL_SERVICE_HTTP_PORT=3306
MYSQL_SERVICE_USER=user
MYSQL_SERVICE_PASSWORD=password
MYSQL_SERVICE_ROOT_PASSWORD=rootpassword
MYSQL_SERVICE_DATABASE=wedding_db

# Docker build configuration
BUILD_DIR=./.docker/wedding-service

# -------------------------------------------------
# Gateway service settings (required by gateway_service)
# For local development, these point to the repo's self-signed certs.
# If running in Docker with the /data volume, you can instead place certs in ./.docker/gateway_service
# and set CERT_PATH=/data/localhost_wedding_service.crt and KEY_PATH=/data/localhost_wedding_service.key
SERVICE_NAME=gateway_service
DEBUG_LEVEL=4
CERT_PATH=services/gateway_service/certificate/self_sign_cert/localhost_wedding_service.crt
KEY_PATH=services/gateway_service/certificate/self_sign_cert/localhost_wedding_service.key

# Map incoming host -> backend URL for gateway reverse proxy
# Format: host=url|host2=url2
GATEWAY_BACKENDS=localhost=http://tinyserver
